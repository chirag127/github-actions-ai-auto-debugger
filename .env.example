# ==============================================================================
# GitHub Actions AI Auto-Debugger (Centralized) - Environment Configuration
# ==============================================================================

# 1. GITHUB APP CONFIGURATION
# ------------------------------------------------------------------------------
# Create an App: https://github.com/settings/apps/new
# Permissions: Actions (Read), Contents (Write), Metadata (Read-only)
# Events: Workflow run (Completed)

# Found in your GitHub App settings under "About"
GH_APP_ID=your_github_app_id

# 1. Download the .pem file from your GitHub App settings (Private keys > Generate a private key).
# 2. Open it in a text editor and copy the entire content (including BEGIN/END lines).
# 3. For Wrangler/Cloudflare, replace newlines with \n: cat private-key.pem | perl -pe 's/\n/\\n/g'
GH_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"


# 2. WEBHOOK CONFIGURATION
# ------------------------------------------------------------------------------
# Set this in your GitHub App settings under "Webhook secret".
# Generate one: openssl rand -base64 32
WEBHOOK_SECRET=your_webhook_secret_here


# 3. PROXY CONFIGURATION (For Wrangler/Cloudflare Deployment)
# ------------------------------------------------------------------------------
# 1. Create a Personal Access Token (Classic): https://github.com/settings/tokens
# 2. Scope: 'repo' or at least 'actions:write' on THIS (management) repository.
# 3. This allows the Proxy to trigger the Central AI Action.
GITHUB_TOKEN=your_personal_access_token_with_actions_write


# ==============================================================================
# AI PROVIDER SELECTION & API KEYS
# ==============================================================================
# Choose your LLM provider by setting AI_PROVIDER.
# Available: cerebras, groq, mistral, google_gemini, nvidia,
#            cohere, huggingface, openrouter, github_models

AI_PROVIDER=cerebras
AI_MODEL=qwen-3-235b-a22b-instruct-2507

# Get Keys here:
# - Cerebras: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# - Groq: https://console.groq.com/keys
GROQ_API_KEY=

# - NVIDIA NIM: https://build.nvidia.com/
NVIDIA_API_KEY=

# - Google Gemini: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# - Mistral AI: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# - Cohere: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# - OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# - Hugging Face: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# - GitHub Models: https://github.com/marketplace/models
GH_MODELS_TOKEN=


# ==============================================================================
# LOCAL TESTING TARGETS
# ==============================================================================
# These are only used for local debugging of src/index.js.
# You can find these in the payload of a failed workflow run webhook.
TARGET_REPO_OWNER=
TARGET_REPO_NAME=
TARGET_RUN_ID=
TARGET_INSTALLATION_ID=
TARGET_HEAD_SHA=
TARGET_BRANCH=


# ==============================================================================
# CLOUDFLARE CONFIGURATION (For Proxy Deployment)
# ==============================================================================
# - Account ID: https://dash.cloudflare.com/ (URL contains the ID)
# - API Token: https://dash.cloudflare.com/profile/api-tokens (Edit Cloudflare Workers template)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_EMAIL=


# ==============================================================================
# LANGFUSE OBSERVABILITY (Optional)
# ==============================================================================
# Obtain these from your Langfuse project settings: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
