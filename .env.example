# ============================================
# GitHub Actions AI Auto-Debugger Configuration
# ============================================

# 1. GITHUB WEBHOOK SECRET
# Generate a random string (e.g., openssl rand -base64 32)
# Set this in your GitHub App settings under "Webhook secret"
WEBHOOK_SECRET=your_webhook_secret_here

# 2. GITHUB APP ID
# Found in your GitHub App settings under "About"
GITHUB_APP_ID=123456

# 3. GITHUB PRIVATE KEY
# Download the .pem file from your GitHub App settings.
# Open it in a text editor and copy the entire content.
# IMPORTANT: When setting this as a Cloudflare Secret,
# it must be the exact content including
# -----BEGIN RSA PRIVATE KEY----- and -----END RSA PRIVATE KEY-----
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ============================================
# AI Provider Selection
# ============================================
# Choose your LLM provider by setting AI_PROVIDER
# Available: google_gemini, cohere, mistral, groq, nvidia, cerebras, huggingface, openrouter, github_models
# Default: cerebras

AI_PROVIDER=cerebras

# Choose the model for your provider
# Default for cerebras: qwen-3-235b-a22b-instruct-2507
# Leave empty to use provider default

AI_MODEL=qwen-3-235b-a22b-instruct-2507

# ============================================
# Provider API Keys
# Set the key for your chosen provider (AI_PROVIDER)
# ============================================

# Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Cohere (https://dashboard.cohere.com/api-keys)
COHERE_API_KEY=your_cohere_api_key_here

# Mistral AI (https://console.mistral.ai/api-keys/)
MISTRAL_API_KEY=your_mistral_api_key_here

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# NVIDIA NIM (https://build.nvidia.com/)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cerebras (https://cloud.cerebras.ai/)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Hugging Face (https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# GitHub Models (https://github.com/marketplace/models)
GITHUB_MODELS_TOKEN=your_github_models_token_here

# ============================================
# LangSmith Observability (Optional but Recommended)
# Obtain these from your Langsmith project settings (https://smith.langchain.com)
# ============================================

LANGSMITH_API_KEY=lsv2_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=github-actions-ai-auto-debugger
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ============================================
# Langfuse Observability (Optional - Alternative to LangSmith)
# Obtain these from your Langfuse project settings (https://cloud.langfuse.com)
# ============================================

LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
